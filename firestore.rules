rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /publicLeaderboard/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId) &&
        request.resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    match /friendships/{friendshipId} {
      allow create: if isSignedIn() &&
        request.resource.data.requesterId == request.auth.uid &&
        request.resource.data.recipientId is string &&
        request.resource.data.requesterId != request.resource.data.recipientId &&
        request.resource.data.users is list &&
        request.resource.data.requesterId in request.resource.data.users &&
        request.resource.data.recipientId in request.resource.data.users;
      allow read: if isSignedIn();
      allow update: if isSignedIn() &&
        resource.data.users is list &&
        request.auth.uid in resource.data.users &&
        request.resource.data.users is list &&
        request.auth.uid in request.resource.data.users &&
        request.resource.data.requesterId == resource.data.requesterId &&
        request.resource.data.recipientId == resource.data.recipientId;
      allow delete: if false;
    }

    match /reflections/{reflectionId} {
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isSignedIn() &&
        resource.data.userId == request.auth.uid;
    }

    match /comments/{commentId} {
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid;
      allow read: if isSignedIn();
      allow update, delete: if isSignedIn() &&
        resource.data.userId == request.auth.uid;
    }

    match /reactions/{reactionId} {
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid;
      allow read: if isSignedIn();
      allow update, delete: if isSignedIn() &&
        resource.data.userId == request.auth.uid;
    }

    match /directMessages/{messageId} {
      allow create: if isSignedIn() &&
        request.resource.data.fromUserId == request.auth.uid &&
        request.auth.uid in request.resource.data.participants;
      allow read: if isSignedIn() &&
        request.auth.uid in resource.data.participants;
      allow update, delete: if false;
    }

    match /friendNotifications/{notificationId} {
      allow create: if isSignedIn() &&
        request.resource.data.fromUserId == request.auth.uid;
      allow read: if isSignedIn() &&
        (resource.data.toUserId == request.auth.uid ||
         resource.data.fromUserId == request.auth.uid);
      allow update: if isSignedIn() &&
        resource.data.toUserId == request.auth.uid;
      allow delete: if false;
    }

    match /activityFeed/{activityId} {
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid;
      allow read: if isSignedIn();
      allow update, delete: if false;
    }

    match /digestSubscriptions/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
